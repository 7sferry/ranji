{
  "name": "ranji",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "concurrently \"bunx @tailwindcss/cli -i src/index.css -o src/output.css --watch\" \"bun --hot index.ts\"",
    "build:css": "bunx @tailwindcss/cli -i src/index.css -o src/output.css --minify",
    "debug": "bun --inspect --hot index.ts",
    "start": "bun index.ts",
    "typecheck": "bun x tsc --noEmit"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.4",
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.2.4"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  }
}
